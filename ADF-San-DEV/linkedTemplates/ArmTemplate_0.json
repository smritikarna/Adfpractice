			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('LS_ASQL_REPORTING_DB_properties_typeProperties_server')]",
					"database": "[parameters('LS_ASQL_REPORTING_DB_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": true,
					"authenticationType": "SQL",
					"userName": "[parameters('LS_ASQL_REPORTING_DB_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('LS_ASQL_REPORTING_DB_password')]"
					}
				}
			},
			"dependsOn": []
		},
